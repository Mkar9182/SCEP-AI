<script>
// ── DATA ────────────────────────────────────────
const SETS=[
  {id:'lower', label:'a–z', size:26, re:/[a-z]/},
  {id:'upper', label:'A–Z', size:26, re:/[A-Z]/},
  {id:'digits',label:'0–9', size:10, re:/[0-9]/},
  {id:'syms',  label:'#@!', size:32, re:/[^a-zA-Z0-9]/},
];
const TIERS=[
  {name:'Critical', color:'var(--c-crit)',  pct:10,  hex:'#FF4060'},
  {name:'Weak',     color:'var(--c-weak)',  pct:30,  hex:'#FF8C40'},
  {name:'Fair',     color:'var(--c-fair)',  pct:55,  hex:'#FFD040'},
  {name:'Strong',   color:'var(--c-strong)',pct:78,  hex:'#40D090'},
  {name:'Excellent',color:'var(--c-excel)', pct:100, hex:'#40A8FF'},
];
const COMMON=['password','123456','qwerty','abc123','letmein','monkey','dragon',
  'master','sunshine','princess','welcome','shadow','superman','football',
  'iloveyou','admin','login','passw0rd','trustno1'];
const SEQ=['0123','1234','2345','3456','4567','5678','6789','abcd','bcde','qwer','asdf','zxcv'];
// Offline mock breach list (swap here for API results later)
const BREACHED=['password','123456','qwerty','abc123','letmein','monkey','dragon','passw0rd','trustno1','iloveyou'];
const ADJ=['Swift','Blazing','Silent','Cosmic','Velvet','Neon','Crystal','Shadow','Golden','Iron','Solar','Frozen'];
const NOUN=['Phoenix','Falcon','Ocean','Cipher','Titan','Storm','Eclipse','Nebula','Forge','Circuit','Prism','Nexus'];
const VERB=['Runs','Flies','Glows','Strikes','Burns','Leaps','Locks','Sparks'];
const SYM=['!','@','#','$','%'];
const LC='abcdefghijkmnopqrstuvwxyz',UC='ABCDEFGHJKLMNPQRSTUVWXYZ',DG='23456789',SP='!@#$%^&*-+=?';
const CAN_HASH=!!(window.crypto && window.crypto.subtle);

// ── UTILS ────────────────────────────────────────
const $=id=>document.getElementById(id);
const rand=a=>a[Math.floor(Math.random()*a.length)];
const rc=s=>s[Math.floor(Math.random()*s.length)];
const cpIco=`<svg width="12" height="12" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>`;

async function hashPw(pw){
  if(!CAN_HASH) return null;
  const data=new TextEncoder().encode(pw);
  const buf=await crypto.subtle.digest('SHA-256', data);
  return Array.from(new Uint8Array(buf)).map(b=>b.toString(16).padStart(2,'0')).join('');
}

function genPw(len=20){
  const pool=LC+UC+DG+SP;
  let r=rc(LC)+rc(UC)+rc(DG)+rc(SP);
  while(r.length<len) r+=rc(pool);
  return [...r].sort(()=>Math.random()-.5).join('');
}
function genPhrase(){
  return `${rand(ADJ)}${rand(VERB)}${rand(NOUN)}${10+Math.floor(Math.random()*90)}${rand(SYM)}`;
}
function crackInfo(entropy){
  const s=Math.pow(2,entropy)/1e9;
  if(s<1)        return['instantly',   'var(--c-crit)'];
  if(s<60)       return['< 1 minute',  'var(--c-crit)'];
  if(s<3600)     return['< 1 hour',    'var(--c-weak)'];
  if(s<86400)    return['< 1 day',     'var(--c-weak)'];
  if(s<2592000)  return['< 1 month',   'var(--c-fair)'];
  if(s<31536000) return['< 1 year',    'var(--c-fair)'];
  if(s<3.15e12)  return['< 100 years', 'var(--c-strong)'];
  return          ['infinitely',        'var(--c-excel)'];
}

function maskPw(pw){
  if(!pw) return '—';
  if(pw.length<=2) return pw[0]+'•';
  return pw[0]+'•'.repeat(Math.min(pw.length-2,8))+pw[pw.length-1];
}
function formatGuesses(log10g){
  if(!isFinite(log10g)) return '—';
  if(log10g<2) return Math.round(Math.pow(10,log10g)).toString();
  if(log10g<6) return Math.round(Math.pow(10,log10g)).toLocaleString();
  return `~10^${log10g.toFixed(1)}`;
}
function formatLogSeconds(log10s){
  if(!isFinite(log10s)) return '—';
  if(log10s<0) return '< 1s';
  if(log10s<7.5){
    const sec=Math.pow(10,log10s);
    if(sec<60) return `${sec.toFixed(1)}s`;
    if(sec<3600) return `${(sec/60).toFixed(1)}m`;
    if(sec<86400) return `${(sec/3600).toFixed(1)}h`;
    if(sec<31557600) return `${(sec/86400).toFixed(1)}d`;
    return `${(sec/31557600).toFixed(1)}y`;
  }
  const years=Math.pow(10,log10s-7.499);
  return `${years.toExponential(1)}y`;
}
function timeAgo(ts){
  const s=Math.floor((Date.now()-ts)/1000);
  if(s<10) return 'just now';
  if(s<60) return `${s}s ago`;
  const m=Math.floor(s/60);
  if(m<60) return `${m}m ago`;
  const h=Math.floor(m/60);
  return `${h}h ago`;
}
function renderRecent(list){
  const el=$('recentList');
  $('clearHistory').disabled=list.length===0;
  if(!list.length){
    el.innerHTML='';
    const row=document.createElement('div');
    row.className='recent-row';
    const pw=document.createElement('span');
    pw.className='recent-pw';
    pw.textContent='No checks yet';
    const t=document.createElement('span');
    t.className='recent-time';
    t.textContent='—';
    row.append(pw,t);
    el.appendChild(row);
    return;
  }
  el.innerHTML='';
  list.forEach(item=>{
    const row=document.createElement('div');
    row.className='recent-row';
    const pw=document.createElement('span');
    pw.className='recent-pw';
    pw.textContent=item.m||'—';
    const t=document.createElement('span');
    t.className='recent-time';
    t.textContent=timeAgo(item.ts);
    row.append(pw,t);
    el.appendChild(row);
  });
}
// ── ANALYSIS ────────────────────────────────────
function analyze(pw){
  let pool=0, detected=[];
  SETS.forEach(s=>{ if(s.re.test(pw)){pool+=s.size; detected.push(s.id);} });
  if(!pool) pool=26;
  const raw=pw.length*Math.log2(pool);
  const issues=[];
  const lo=pw.toLowerCase();
  if(COMMON.some(w=>lo.includes(w)))        issues.push('Contains a common or dictionary word');
  if(SEQ.some(s=>lo.includes(s)))           issues.push('Sequential characters found (e.g. 1234, abcd)');
  const ch=[...pw];
  if(ch.some((c,i)=>i>=2&&c===ch[i-1]&&c===ch[i-2])) issues.push('3+ repeated characters in a row');
  if(new Set(pw).size/pw.length<0.4&&pw.length>4) issues.push('Low character diversity');
  if(pw.length<8)       issues.push('Too short — minimum 8 characters');
  else if(pw.length<12) issues.push('Short — 12+ characters recommended');
  const entropy=Math.max(0,raw-issues.length*8);
  let tier=0;
  if(entropy>=80) tier=4; else if(entropy>=60) tier=3;
  else if(entropy>=40) tier=2; else if(entropy>=28) tier=1;
  const score=Math.min(entropy/80,1);
  const [crack,crackColor]=crackInfo(entropy);
  return {entropy,raw,pool,length:pw.length,unique:new Set(pw).size,detected,issues,tier,score,crack,crackColor,rawPwLower:lo};
}

// ── CLOCK ───────────────────────────────────────
function updateClock(){
  const now=new Date();
  let h=now.getHours(), m=now.getMinutes();
  const ampm=h>=12?'PM':'AM';
  h=h%12||12;
  $('clockTime').textContent=`${h}:${m.toString().padStart(2,'0')}`;
}
updateClock(); setInterval(updateClock,10000);

// ── SUGGESTIONS ─────────────────────────────────
let suggs=[], phrase='';
function refreshSuggs(){
  suggs=[genPw(),genPw(),genPw()]; phrase=genPhrase(); renderSuggs();
}
function renderSuggs(){
  $('suggList').innerHTML=suggs.map((pw,i)=>{
    const a=analyze(pw);
    return `<div class="sugg-row">
      <span class="sugg-pw">${pw}</span>
      <span class="sugg-bits">${a.entropy.toFixed(0)}b</span>
      <button class="copy-btn" onclick="doCopy('${pw}','Password copied')">${cpIco}</button>
    </div>`;
  }).join('');
  $('phraseVal').textContent=phrase;
  $('phraseBtn').onclick=()=>doCopy(phrase,'Passphrase copied');
}

// ── UPDATE UI ────────────────────────────────────
function update(pw){
  const hasVal=pw.length>0;
  $('clearBtn').classList.toggle('hidden',!hasVal);
  $('charCount').textContent=`${pw.length} char${pw.length!==1?'s':''}`;

  if(!hasVal){
    reuseFlag=false;
    breachState='idle';
    $('empty').classList.remove('hidden');
    $('results').classList.add('hidden');
    $('bitsLbl').textContent='— bits';
    $('bitsLbl').style.color='var(--text-3)';
    renderRecent(recentPw);
    return;
  }
  $('empty').classList.add('hidden');
  $('results').classList.remove('hidden');

  const a=analyze(pw); const t=TIERS[a.tier];

  // Bits label
  $('bitsLbl').textContent=`${a.entropy.toFixed(1)} bits`;
  $('bitsLbl').style.color=t.color;

  // Strength
  $('sName').textContent=t.name; $('sName').style.color=t.color;

  // Ring
  const circ=2*Math.PI*27;
  const rf=$('ringFg');
  rf.style.strokeDashoffset=`${circ*(1-a.score)}`;
  rf.style.stroke=t.hex;
  $('ringNum').textContent=Math.round(a.score*100);

  // Bar
  $('barFill').style.width=`${t.pct}%`;
  $('barFill').style.backgroundColor=t.hex;

  // Crack
  $('crackVal').textContent=a.crack; $('crackVal').style.color=a.crackColor;

  // Breach (offline mock)
  let breachTxt='—', breachColor='var(--text-3)';
  if(breachState==='checking'){ breachTxt='Checking…'; breachColor='var(--text-2)'; }
  if(breachState==='exposed'){ breachTxt='Exposed'; breachColor='var(--c-crit)'; }
  if(breachState==='safe'){ breachTxt='Not found'; breachColor='var(--c-strong)'; }
  if(breachState==='error'){ breachTxt='Unavailable'; breachColor='var(--c-weak)'; }
  $('breachVal').textContent=breachTxt;
  $('breachVal').style.color=breachColor;

  // Guessability
  const log10g=a.entropy*0.30103;
  const log10Online=log10g-2; // 100 guesses/sec
  const log10Offline=log10g-9; // 1B guesses/sec
  $('guessOnline').textContent=formatLogSeconds(log10Online);
  $('guessOffline').textContent=formatLogSeconds(log10Offline);
  $('guessCount').textContent=`Estimated guesses: ${formatGuesses(log10g)}`;

  // Stats
  $('stEnt').textContent=`${a.entropy.toFixed(0)}b`;
  $('stPool').textContent=`${a.pool}`;
  $('stUniq').textContent=`${a.unique}`;

  // Pills
  $('pills').innerHTML=SETS.map(s=>`
    <div class="pill ${a.detected.includes(s.id)?'on':'off'}">
      <span class="pill-dot"></span>${s.label}
    </div>
  `).join('');

  // Issues
  const iw=$('issuesWrap');
  const allIssues=reuseFlag ? [...a.issues, 'Password reused recently'] : a.issues;
  if(allIssues.length){
    iw.classList.remove('hidden');
    $('issuesList').innerHTML=allIssues.map((iss,i)=>`
      <div class="issue" style="animation-delay:${i*0.06}s">
        <span class="issue-i">
          <svg width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <circle cx="12" cy="12" r="10"/>
            <line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>
          </svg>
        </span>${iss}
      </div>`).join('');
  } else { iw.classList.add('hidden'); }

  // Recent list
  renderRecent(recentPw);
}

// ── COPY ────────────────────────────────────────
function doCopy(txt,msg='Copied'){
  if(navigator.clipboard && window.isSecureContext){
    navigator.clipboard.writeText(txt).then(()=>showToast(msg)).catch(()=>fallbackCopy(txt,msg));
  } else {
    fallbackCopy(txt,msg);
  }
}
function fallbackCopy(txt,msg){
  const ta=document.createElement('textarea');
  ta.value=txt;
  ta.setAttribute('readonly','');
  ta.style.position='fixed';
  ta.style.opacity='0';
  document.body.appendChild(ta);
  ta.select();
  let ok=false;
  try{ ok=document.execCommand('copy'); }catch(e){ ok=false; }
  document.body.removeChild(ta);
  showToast(ok?msg:'Failed');
}
let toastT;
function showToast(msg){
  const el=$('toast'); $('toastMsg').textContent=msg;
  el.classList.add('show'); clearTimeout(toastT);
  toastT=setTimeout(()=>el.classList.remove('show'),2000);
}

// ── EVENTS ──────────────────────────────────────
let visible=false;
let reuseFlag=false;
let reuseTimer;
let breachState='idle';
let breachTimer;
const recentPw=[];
const input=$('pwInput');
input.addEventListener('input',()=>{
  const pw=input.value;
  update(pw);
  clearTimeout(reuseTimer);
  clearTimeout(breachTimer);
  reuseTimer=setTimeout(async()=>{
    const lo=pw.toLowerCase();
    if(!CAN_HASH || !lo){
      reuseFlag=false;
      update(pw);
      return;
    }
    const h=await hashPw(lo);
    reuseFlag=!!h && recentPw.some(r=>r.h===h);
    if(h && recentPw[recentPw.length-1]?.h!==h){
      const item={h, m:maskPw(pw), ts:Date.now()};
      recentPw.push(item);
      if(recentPw.length>10) recentPw.shift();
    }
    update(pw);
  },400);
  breachTimer=setTimeout(async()=>{
    if(!pw){ breachState='idle'; update(''); return; }
    breachState='checking'; update(pw);
    try{
      const exposed=BREACHED.includes(pw.toLowerCase());
      breachState=exposed?'exposed':'safe';
    } catch(e){
      breachState='error';
    }
    update(pw);
  },450);
});
$('toggleBtn').addEventListener('click',()=>{
  visible=!visible; input.type=visible?'text':'password';
  $('eyeSvg').innerHTML=visible
    ?`<path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"/><line x1="1" y1="1" x2="23" y2="23"/>`
    :`<path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>`;
});
$('clearBtn').addEventListener('click',()=>{ input.value=''; update(''); input.focus(); });
$('regenBtn').addEventListener('click', refreshSuggs);
$('clearHistory').addEventListener('click',()=>{
  recentPw.length=0;
  update(input.value);
});

// ── INIT ────────────────────────────────────────
renderRecent(recentPw);
refreshSuggs();
</script>
