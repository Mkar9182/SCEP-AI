<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<meta http-equiv="Content-Security-Policy" content="default-src 'self'; base-uri 'self'; form-action 'none'; frame-ancestors 'none'; img-src 'self' data:; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src https://fonts.gstatic.com; script-src 'self' 'unsafe-inline'; connect-src 'self'"/>
<title>SCEP AI</title>
<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet"/>
<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

:root {
  --phone-w: 390px;
  --phone-h: 844px;
  --bg-page: #0E0E10;
  --app-bg:  #0A0A0F;
  --surface: #13131A;
  --surface2: #1A1A24;
  --border:  #2A2A38;
  --border2: #3A3A50;
  --text:    #F0F0F5;
  --text-2:  #8888A0;
  --text-3:  #444460;

  --c-crit:  #FF4060;
  --c-weak:  #FF8C40;
  --c-fair:  #FFD040;
  --c-strong:#cdf75b;
  --c-excel: #40A8FF;

  --font:    'Outfit', sans-serif;
  --mono:    'JetBrains Mono', monospace;
  --ease:    cubic-bezier(0.4,0,0.2,1);
  --spring:  cubic-bezier(0.34,1.4,0.64,1);
  --bounce:  cubic-bezier(0.68,-0.55,0.27,1.55);
}

html, body {
  height: 100%;
  font-family: var(--font);
  background: var(--bg-page);
  display: flex; align-items: center; justify-content: center;
  -webkit-font-smoothing: antialiased;
  overflow: hidden;
}

/* ── DESKTOP SCENE ── */
.scene {
  position: relative;
  display: flex; align-items: center; justify-content: center;
  width: 100vw; height: 100vh;
}

/* ambient glow behind phone */
.scene-glow {
  position: absolute;
  width: 500px; height: 500px; border-radius: 50%;
  background: radial-gradient(circle, #40A8FF14 0%, transparent 70%);
  pointer-events: none;
  animation: glowPulse 6s ease-in-out infinite;
}

/* ── PHONE SHELL ── */
.phone {
  position: relative;
  width: var(--phone-w);
  height: var(--phone-h);
  border-radius: 52px;
  background: #1C1C22;
  box-shadow:
    0 0 0 1.5px #3A3A50,
    0 0 0 3px #111118,
    0 0 0 4px #2A2A38,
    0 30px 80px rgba(0,0,0,0.7),
    0 0 120px rgba(64,168,255,0.06),
    inset 0 1px 0 rgba(255,255,255,0.08),
    inset 0 -1px 0 rgba(0,0,0,0.5);
  animation: phoneIn 0.8s var(--spring) both;
  flex-shrink: 0;
}

/* Side buttons */
.phone::before {
  content: '';
  position: absolute;
  left: -4px; top: 130px;
  width: 4px; height: 36px;
  background: #2A2A38;
  border-radius: 3px 0 0 3px;
  box-shadow: 0 50px 0 #2A2A38, 0 96px 0 #2A2A38;
}
.phone::after {
  content: '';
  position: absolute;
  right: -4px; top: 160px;
  width: 4px; height: 64px;
  background: #2A2A38;
  border-radius: 0 3px 3px 0;
}

/* Screen bezel */
.screen-bezel {
  position: absolute;
  inset: 8px;
  border-radius: 46px;
  background: var(--app-bg);
  overflow: hidden;
}

/* ── STATUS BAR ── */
.status-bar {
  position: absolute; top: 0; left: 0; right: 0;
  height: 50px; padding: 14px 28px 0;
  display: flex; align-items: center; justify-content: space-between;
  z-index: 10;
}
.status-time { font-size: 15px; font-weight: 600; color: var(--text); letter-spacing: -0.3px; }
.status-icons { display: flex; align-items: center; gap: 6px; }
.status-icons svg { color: var(--text); }

/* Dynamic island */
.dynamic-island {
  position: absolute; top: 12px; left: 50%; transform: translateX(-50%);
  width: 120px; height: 34px;
  background: #000;
  border-radius: 20px;
  z-index: 20;
  display: flex; align-items: center; justify-content: center;
  box-shadow: 0 0 0 1px #1a1a1a;
}

/* ── APP SCROLL AREA ── */
.app-scroll {
  position: absolute;
  top: 50px; bottom: 0; left: 0; right: 0;
  overflow-y: auto;
  overflow-x: hidden;
  -webkit-overflow-scrolling: touch;
  scrollbar-width: none;
}
.app-scroll::-webkit-scrollbar { display: none; }

.app-inner {
  padding: 16px 22px 48px;
  min-height: calc(100% + 1px);
}

/* ── APP HEADER ── */
.app-header {
  display: flex; align-items: center; justify-content: space-between;
  margin-bottom: 28px;
  padding-top: 4px;
  opacity: 0; animation: slideDown 0.5s var(--ease) 0.2s forwards;
}
.app-logo { display: flex; align-items: center; gap: 9px; }
.app-logo-icon {
  width: 36px; height: 36px; border-radius: 10px;
  background: linear-gradient(135deg, #40A8FF, #1060CC);
  display: flex; align-items: center; justify-content: center;
  font-size: 17px;
  box-shadow: 0 4px 16px rgba(64,168,255,0.35);
}
.app-logo-text { font-size: 18px; font-weight: 700; color: var(--text); letter-spacing: -0.5px; }
.app-header-tag {
  font-family: var(--mono); font-size: 10px; color: var(--text-3);
  letter-spacing: 0.8px; text-transform: uppercase;
}

/* ── INPUT CARD ── */
.input-card {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 20px;
  padding: 18px;
  margin-bottom: 14px;
  opacity: 0; animation: slideUp 0.5s var(--ease) 0.3s forwards;
}
.input-card-label {
  font-size: 11px; font-weight: 500; color: var(--text-3);
  letter-spacing: 1.2px; text-transform: uppercase; margin-bottom: 12px;
}
.input-row {
  display: flex; align-items: center; gap: 8px;
  background: var(--app-bg);
  border: 1.5px solid var(--border);
  border-radius: 14px; padding: 0 14px; height: 50px;
  transition: border-color 0.2s, box-shadow 0.2s;
}
.input-row:focus-within {
  border-color: var(--c-excel);
  box-shadow: 0 0 0 3px rgba(64,168,255,0.12);
}
.input-row input {
  flex: 1; background: none; border: none; outline: none;
  font-family: var(--mono); font-size: 13px; color: var(--text);
  letter-spacing: 0.5px;
}
.input-row input::placeholder { font-family: var(--font); font-size: 13px; color: var(--text-3); letter-spacing: 0; }
.ibtn {
  background: none; border: none; cursor: pointer;
  color: var(--text-3); display: flex; align-items: center; justify-content: center;
  width: 28px; height: 28px; border-radius: 7px; flex-shrink: 0;
  transition: color 0.15s, background 0.15s;
}
.ibtn:hover { color: var(--text-2); background: var(--surface2); }

.input-foot {
  display: flex; justify-content: space-between;
  margin-top: 10px; font-size: 11px; color: var(--text-3); font-weight: 500;
}
.i-bits { font-family: var(--mono); transition: color 0.3s; }

/* ── STRENGTH CARD ── */
.strength-card {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 20px; padding: 18px;
  margin-bottom: 14px;
  opacity: 0; animation: slideUp 0.5s var(--ease) 0.38s forwards;
}
.s-top { display: flex; align-items: flex-start; justify-content: space-between; margin-bottom: 16px; }
.s-left {}
.s-label { font-size: 10px; font-weight: 600; color: var(--text-3); letter-spacing: 1.5px; text-transform: uppercase; margin-bottom: 4px; }
.s-name {
  font-size: 32px; font-weight: 800; letter-spacing: -1.5px; line-height: 1;
  color: var(--text-3); transition: color 0.4s var(--ease);
}
.s-name.live { color: var(--text); }
.s-right { display: flex; flex-direction: column; align-items: flex-end; gap: 6px; }

/* score ring */
.ring-wrap { position: relative; width: 64px; height: 64px; flex-shrink: 0; }
.ring-wrap svg { transform: rotate(-90deg); }
.ring-bg  { fill: none; stroke: var(--border); stroke-width: 5; }
.ring-fg  { fill: none; stroke-width: 5; stroke-linecap: round; transition: stroke-dashoffset 0.7s var(--spring), stroke 0.4s; }
.ring-num {
  position: absolute; inset: 0;
  display: flex; align-items: center; justify-content: center;
  font-family: var(--mono); font-size: 16px; font-weight: 600; color: var(--text);
}

/* Bar */
.s-bar-track {
  height: 6px; background: var(--border);
  border-radius: 99px; overflow: hidden;
}
.s-bar-fill {
  height: 100%; border-radius: 99px; width: 0%;
  transition: width 0.7s var(--spring), background-color 0.4s;
  position: relative;
}

/* Crack row */
.crack-row {
  display: flex; align-items: center; justify-content: space-between;
  background: var(--surface2); border-radius: 10px;
  padding: 10px 14px; margin-top: 12px;
}
.crack-label-txt { font-size: 11px; color: var(--text-3); font-weight: 500; }
.crack-val { font-family: var(--mono); font-size: 12px; font-weight: 600; transition: color 0.3s; }

/* Breach row */
.breach-row {
  display: flex; align-items: center; justify-content: space-between;
  background: var(--surface2); border-radius: 10px;
  padding: 10px 14px; margin-top: 8px;
}
.breach-label { font-size: 11px; color: var(--text-3); font-weight: 500; }
.breach-val { font-family: var(--mono); font-size: 12px; font-weight: 600; transition: color 0.3s; }

/* ── STATS GRID ── */
.stats-grid {
  display: grid; grid-template-columns: repeat(3,1fr);
  gap: 8px; margin-bottom: 14px;
  opacity: 0; animation: slideUp 0.5s var(--ease) 0.44s forwards;
}
.stat-tile {
  background: var(--surface); border: 1px solid var(--border);
  border-radius: 16px; padding: 14px 12px;
  display: flex; flex-direction: column; gap: 5px;
  transition: border-color 0.2s, transform 0.2s;
}
.stat-tile:active { transform: scale(0.97); }
.stat-label { font-size: 10px; font-weight: 500; color: var(--text-3); letter-spacing: 0.8px; text-transform: uppercase; }
.stat-val { font-family: var(--mono); font-size: 17px; font-weight: 600; color: var(--text); }

/* ── PILL ROW ── */
.pills {
  display: flex; gap: 6px; flex-wrap: wrap;
  margin-bottom: 14px;
  opacity: 0; animation: slideUp 0.5s var(--ease) 0.48s forwards;
}
.pill {
  font-size: 11px; font-weight: 600;
  padding: 6px 12px; border-radius: 99px;
  border: 1.5px solid transparent;
  display: flex; align-items: center; gap: 5px;
  transition: all 0.25s var(--ease);
}
.pill.on  { background: var(--text); color: var(--app-bg); border-color: var(--text); }
.pill.off { background: transparent; color: var(--text-3); border-color: var(--border); }
.pill-dot { width: 5px; height: 5px; border-radius: 50%; background: currentColor; flex-shrink:0; }

/* ── ISSUES ── */
.issues-wrap {
  margin-bottom: 14px;
  opacity: 0; animation: slideUp 0.5s var(--ease) 0.5s forwards;
}
.issue {
  display: flex; align-items: flex-start; gap: 10px;
  padding: 11px 13px; margin-bottom: 6px;
  background: rgba(255,64,96,0.07);
  border: 1px solid rgba(255,64,96,0.18);
  border-left: 3px solid var(--c-crit);
  border-radius: 12px;
  font-size: 12px; color: #FF9AAA; line-height: 1.45;
  opacity: 0; animation: slideIn 0.25s var(--ease) forwards;
}
.issue:last-child { margin-bottom: 0; }
.issue-i { flex-shrink: 0; margin-top: 1px; color: var(--c-crit); }

/* ── GUESSABILITY ── */
.guess-card {
  background: var(--surface); border: 1px solid var(--border);
  border-radius: 20px; padding: 18px; margin-bottom: 14px;
  opacity: 0; animation: slideUp 0.5s var(--ease) 0.505s forwards;
}
.guess-row {
  display: flex; align-items: center; justify-content: space-between;
  background: var(--surface2); border-radius: 10px;
  padding: 10px 14px; margin-top: 8px;
}
.guess-row:first-of-type { margin-top: 0; }
.guess-label { font-size: 11px; color: var(--text-3); font-weight: 500; }
.guess-val { font-family: var(--mono); font-size: 12px; font-weight: 600; color: var(--text); }
.guess-sub { font-size: 10px; color: var(--text-3); margin-top: 8px; }

/* ── RECENT CHECKS ── */
.recent-card {
  background: var(--surface); border: 1px solid var(--border);
  border-radius: 20px; padding: 18px; margin-bottom: 14px;
  opacity: 0; animation: slideUp 0.5s var(--ease) 0.51s forwards;
}
.recent-list { display: flex; flex-direction: column; gap: 6px; }
.recent-row {
  display: flex; align-items: center; justify-content: space-between;
  background: var(--surface2); border: 1px solid var(--border);
  border-radius: 12px; padding: 10px 12px;
  font-size: 12px;
}
.recent-pw { font-family: var(--mono); color: var(--text); }
.recent-time { font-size: 10px; color: var(--text-3); font-weight: 600; letter-spacing: 0.6px; }
.recent-actions { display: flex; justify-content: flex-end; margin-top: 10px; }
.clear-btn {
  background: var(--surface2); border: 1px solid var(--border);
  border-radius: 12px; padding: 6px 10px; cursor: pointer;
  font-family: var(--font); font-size: 10px; font-weight: 600; color: var(--text-2);
  transition: background 0.15s, color 0.15s, transform 0.15s;
}
.clear-btn:hover { background: var(--border); color: var(--text); }
.clear-btn:active { transform: scale(0.97); }
.clear-btn:disabled { opacity: 0.5; cursor: default; }
.clear-btn:disabled:hover { background: var(--surface2); color: var(--text-2); }

/* ── SUGGESTIONS CARD ── */
.sugg-card {
  background: var(--surface); border: 1px solid var(--border);
  border-radius: 20px; padding: 18px; margin-bottom: 14px;
  opacity: 0; animation: slideUp 0.5s var(--ease) 0.52s forwards;
}
.card-header {
  display: flex; align-items: center; justify-content: space-between;
  margin-bottom: 14px;
}
.card-title { font-size: 11px; font-weight: 600; color: var(--text-3); letter-spacing: 1.2px; text-transform: uppercase; }
.regen-btn {
  background: var(--surface2); border: 1px solid var(--border);
  border-radius: 20px; padding: 5px 11px; cursor: pointer;
  font-family: var(--font); font-size: 11px; font-weight: 600; color: var(--text-2);
  display: flex; align-items: center; gap: 5px;
  transition: background 0.15s, color 0.15s, transform 0.15s;
}
.regen-btn:hover { background: var(--border); color: var(--text); }
.regen-btn:active { transform: scale(0.95); }
.regen-btn svg { transition: transform 0.4s var(--ease); }
.regen-btn:active svg { transform: rotate(180deg); }

.sugg-list { display: flex; flex-direction: column; gap: 6px; }
.sugg-row {
  display: flex; align-items: center; gap: 10px;
  background: var(--surface2); border: 1px solid var(--border);
  border-radius: 12px; padding: 11px 12px;
  transition: border-color 0.2s, background 0.2s;
}
.sugg-row:active { background: var(--border); }
.sugg-pw { flex: 1; font-family: var(--mono); font-size: 12px; color: var(--text); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; min-width: 0; }
.sugg-bits { font-family: var(--mono); font-size: 10px; color: var(--text-3); flex-shrink: 0; white-space: nowrap; }
.copy-btn {
  background: var(--surface); border: 1px solid var(--border);
  border-radius: 8px; cursor: pointer;
  width: 30px; height: 30px;
  display: flex; align-items: center; justify-content: center;
  color: var(--text-3); flex-shrink: 0;
  transition: background 0.15s, color 0.15s, transform 0.1s;
}
.copy-btn:hover { background: var(--border2); color: var(--text); }
.copy-btn:active { transform: scale(0.88); }

.divider { border: none; border-top: 1px solid var(--border); margin: 12px 0; }

.phrase-row {
  display: flex; align-items: center; gap: 10px;
  background: rgba(64,168,255,0.06);
  border: 1px solid rgba(64,168,255,0.15);
  border-radius: 12px; padding: 11px 12px;
}
.phrase-tag { font-size: 9px; font-weight: 600; letter-spacing: 1px; text-transform: uppercase; color: var(--c-excel); flex-shrink: 0; }
.phrase-val { flex: 1; font-family: var(--mono); font-size: 12px; color: var(--text); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }


/* ── HOME BAR ── */
.home-bar {
  position: absolute; bottom: 10px; left: 50%; transform: translateX(-50%);
  width: 130px; height: 5px; background: rgba(255,255,255,0.25);
  border-radius: 99px;
}

/* ── EMPTY STATE ── */
#empty {
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  padding: 48px 20px 20px; text-align: center;
}
.empty-icon {
  font-size: 52px; margin-bottom: 20px;
  display: block; animation: float 4s ease-in-out infinite;
  filter: drop-shadow(0 0 24px rgba(64,168,255,0.3));
}
.empty-h { font-size: 20px; font-weight: 700; color: var(--text); letter-spacing: -0.5px; margin-bottom: 8px; }
.empty-p { font-size: 13px; color: var(--text-2); line-height: 1.6; max-width: 260px; margin: 0 auto 24px; }
.empty-chips { display: flex; justify-content: center; gap: 6px; flex-wrap: wrap; }
.empty-chip { font-family: var(--mono); font-size: 9px; color: var(--text-3); padding: 4px 10px; border-radius: 99px; border: 1px solid var(--border); letter-spacing: 0.5px; }

/* ── TOAST ── */
#toast {
  position: absolute; bottom: 28px; left: 50%;
  transform: translateX(-50%) translateY(8px);
  background: var(--text); color: var(--app-bg);
  font-size: 12px; font-weight: 600;
  padding: 9px 16px; border-radius: 99px;
  display: flex; align-items: center; gap: 7px;
  opacity: 0; pointer-events: none; z-index: 100;
  transition: opacity 0.2s, transform 0.2s;
  white-space: nowrap;
  box-shadow: 0 4px 20px rgba(0,0,0,0.4);
}
#toast.show { opacity: 1; transform: translateX(-50%) translateY(0); }
.t-ok { width: 6px; height: 6px; border-radius: 50%; background: var(--c-strong); flex-shrink: 0; }

.hidden { display: none !important; }

/* ── ANIMATIONS ── */
@keyframes phoneIn {
  from { opacity: 0; transform: translateY(40px) scale(0.95); }
  to   { opacity: 1; transform: translateY(0) scale(1); }
}
@keyframes slideDown {
  from { opacity: 0; transform: translateY(-10px); }
  to   { opacity: 1; transform: translateY(0); }
}
@keyframes slideUp {
  from { opacity: 0; transform: translateY(14px); }
  to   { opacity: 1; transform: translateY(0); }
}
@keyframes slideIn {
  from { opacity: 0; transform: translateX(-6px); }
  to   { opacity: 1; transform: translateX(0); }
}
@keyframes float {
  0%,100% { transform: translateY(0); }
  50%      { transform: translateY(-8px); }
}
@keyframes glowPulse {
  0%,100% { opacity: 1; transform: scale(1); }
  50%      { opacity: 0.6; transform: scale(1.1); }
}

/* ── RESPONSIVE: on small screens show as full page ── */
@media (max-width: 500px) or (max-height: 880px) {
  html, body { align-items: flex-start; overflow: auto; }
  .scene { min-height: 100vh; height: auto; padding: 20px 0; align-items: flex-start; }
  .phone { width: 100%; max-width: var(--phone-w); height: auto; border-radius: 0; box-shadow: none; }
  .phone::before, .phone::after { display: none; }
  .screen-bezel { position: static; border-radius: 0; height: auto; overflow: visible; }
  .app-scroll { position: static; overflow: visible; height: auto; }
  .status-bar { display: none; }
  .dynamic-island { display: none; }
  .home-bar { display: none; }
  .scene-glow { display: none; }
}
</style>
</head>
<body>
<div class="scene">
  <div class="scene-glow"></div>

  <div class="phone">
    <!-- Dynamic Island -->
    <div class="dynamic-island"></div>

    <div class="screen-bezel">

      <!-- Status Bar -->
      <div class="status-bar">
        <span class="status-time" id="clockTime">9:41</span>
        <div class="status-icons">
          <!-- Signal -->
          <svg width="17" height="12" viewBox="0 0 17 12" fill="currentColor">
            <rect x="0" y="8" width="3" height="4" rx="0.5" opacity="0.4"/>
            <rect x="4.5" y="5.5" width="3" height="6.5" rx="0.5" opacity="0.6"/>
            <rect x="9" y="3" width="3" height="9" rx="0.5" opacity="0.8"/>
            <rect x="13.5" y="0" width="3" height="12" rx="0.5"/>
          </svg>
          <!-- Wifi -->
          <svg width="15" height="12" viewBox="0 0 15 12" fill="currentColor">
            <path d="M7.5 9.5a1.5 1.5 0 1 1 0 3 1.5 1.5 0 0 1 0-3z"/>
            <path d="M2.8 6.3a6.7 6.7 0 0 1 9.4 0" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" opacity="0.7"/>
            <path d="M0 3.5a10.5 10.5 0 0 1 15 0" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" opacity="0.4"/>
          </svg>
          <!-- Battery -->
          <svg width="25" height="12" viewBox="0 0 25 12" fill="none">
            <rect x="0.5" y="0.5" width="21" height="11" rx="3" stroke="currentColor" stroke-opacity="0.5"/>
            <rect x="2" y="2" width="15" height="8" rx="1.5" fill="currentColor"/>
            <path d="M23 4v4a2 2 0 0 0 0-4z" fill="currentColor" opacity="0.5"/>
          </svg>
        </div>
      </div>

      <!-- Scrollable App -->
      <div class="app-scroll" id="appScroll">
        <div class="app-inner">

          <!-- App Header -->
          <div class="app-header">
            <div class="app-logo">
